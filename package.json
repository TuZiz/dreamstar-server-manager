{
  "name": "dreamstar-server-manager",
  "version": "0.1.0",
  "description": "Windows-first local Minecraft multi-server and database manager.",
  "main": "out/main/index.js",
  "author": "DreamStar",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "dev:web": "concurrently -k \"npm:dev:server\" \"npm:dev:renderer\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:renderer": "vite --config vite.web.config.ts",
    "start:web": "tsx src/server/index.ts",
    "build": "npm run typecheck && electron-vite build",
    "build:web": "npm run typecheck && vite build --config vite.web.config.ts",
    "typecheck": "tsc --noEmit",
    "preview": "electron-vite preview"
  },
  "dependencies": {
    "express": "latest",
    "ioredis": "latest",
    "lucide-react": "latest",
    "mysql2": "latest",
    "pg": "latest",
    "react": "latest",
    "react-dom": "latest",
    "react-router-dom": "latest",
    "zustand": "latest"
  },
  "devDependencies": {
    "@types/express": "latest",
    "@types/node": "latest",
    "@types/pg": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "^5.1.2",
    "autoprefixer": "^10.4.20",
    "concurrently": "latest",
    "electron": "^42.3.0",
    "electron-vite": "latest",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "latest",
    "typescript": "latest",
    "vite": "^7.3.3"
  }
}
